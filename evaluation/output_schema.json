{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/notoow/opendefender-triage-benchmark/schemas/model-output.schema.json",
  "title": "OpenDefender Model Triage Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "incident_type",
    "severity",
    "confidence",
    "evidence",
    "missing_information",
    "recommended_actions",
    "safety_notes"
  ],
  "properties": {
    "incident_type": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "critical"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
